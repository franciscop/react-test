{
  "name": "react-test",
  "version": "0.22.1",
  "description": "Expressive testing library for React to make sure your code works as expected. Write better code, ship fewer bugs.",
  "homepage": "https://react-test.dev/",
  "repository": "https://github.com/franciscop/react-test.git",
  "bugs": "https://github.com/franciscop/react-test/issues",
  "funding": "https://www.paypal.me/franciscopresencia/19",
  "author": "Francisco Presencia <public@francisco.io> (https://francisco.io/)",
  "documentation": {
    "title": "🧯 React Test - Expressive testing library for React",
    "home": "assets/home.html",
    "menu": {
      "Documentation": "/documentation",
      "Issues": "https://github.com/franciscop/react-test/issues",
      "Contribute": "https://github.com/franciscop/react-test/blob/master/Contributing.md",
      "Get help": "https://superpeer.com/francisco/-/javascript-and-react-help",
      "Github": "https://github.com/franciscop/react-test"
    },
    "pages": [
      "readme.md",
      "src/methods",
      "src/helpers",
      "src/jest-matchers",
      "src/examples"
    ]
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && rollup -c",
    "lint": "prettier src --write && tsc",
    "size": "echo $(gzip -c index.min.js | wc -c) bytes",
    "start": "jest src/ --watch",
    "test": "jest ./src/ --coverage --detectOpenHandles"
  },
  "keywords": [
    "react",
    "test",
    "testing",
    "expressive",
    "jest"
  ],
  "main": "index.min.js",
  "types": "index.d.ts",
  "files": [
    "index.d.ts"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@rollup/plugin-babel": "^6.0.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.4",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^2.4.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "rollup": "^4.60.1",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^6.0.2"
  },
  "babel": {
    "presets": [
      "@babel/preset-env",
      "@babel/preset-react",
      "@babel/preset-typescript"
    ]
  },
  "jest": {
    "testEnvironment": "jsdom",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "src/**/*.tsx",
      "!src/**/*.test.ts",
      "!src/**/*.test.tsx"
    ]
  }
}
